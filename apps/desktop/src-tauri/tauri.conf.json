{
    "$schema": "https://schema.tauri.app/config/2.0.0",
    "productName": "DronePlan",
    "version": "0.1.0",
    "identifier": "com.droneplan.app",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "DronePlan - RC 2 任务规划",
                "width": 1400,
                "height": 900,
                "minWidth": 1000,
                "minHeight": 700,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "msi"
        ],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/icon.ico"
        ],
        "windows": {
            "wix": {
                "language": "zh-CN"
            }
        }
    }
}
